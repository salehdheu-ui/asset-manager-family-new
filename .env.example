# اتصال قاعدة البيانات (PostgreSQL) — إلزامي
DATABASE_URL=postgres://user:password@host:5432/database

# سر تشفير الجلسات — إلزامي في الإنتاج (استخدم قيمة عشوائية طويلة)
SESSION_SECRET=change-me-to-a-long-random-string

# إنشاء حساب مدير افتراضي عند الإقلاع (مرة واحدة فقط ثم عطّلها)
# SEED_ADMIN=true
# ADMIN_PASSWORD=strong-password-at-least-8-chars

# منفذ الخادم (اختياري — الافتراضي 5000)
# PORT=5000

# نسخ احتياطي خارجي تلقائي (اختياري): كل نسخة تُرفع لهذا الرابط بطلب POST
# يصلح مع Google Apps Script Web App لحفظها في Google Drive، أو أي Webhook
# BACKUP_PUSH_URL=https://script.google.com/macros/s/XXXX/exec
# BACKUP_PUSH_SECRET=random-shared-secret
